# Database connection string
# Local development (PostgreSQL via Docker or local install):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mob_api?schema=public
# Production (PostgreSQL on Render - set automatically via render.yaml):
# DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

# JWT secret used to sign authentication tokens
JWT_SECRET=your_jwt_secret_here

# Application environment
NODE_ENV=development

# Port the API listens on (default: 8080)
PORT=8080
